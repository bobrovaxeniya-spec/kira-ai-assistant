# Пример переменных окружения для локального запуска
# Скопируйте в `.env` и заполните значениями

TELEGRAM_BOT_TOKEN=your-telegram-bot-token
OLLAMA_API_URL=http://localhost:11434/v1/chat/completions
OLLAMA_MODEL=llama3.2:3b
# Port for the internal health endpoint (liveness/readiness)
HEALTH_PORT=8080

# If you run Ollama on the host and use Docker on macOS, set:
# OLLAMA_API_URL=http://host.docker.internal:11434/v1/chat/completions
