[Unit]
Description=Kira AI Polling Bot (runs inside api container)
After=docker.service

[Service]
Type=simple
User=aiagent
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/docker compose -f /home/aiagent/kira-ai-assistant/docker-compose.yml exec -T api python deploy/polling_bot.py
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
